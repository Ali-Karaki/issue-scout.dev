# GitHub token (required; for API rate limits)
# Copy to .env.local and add your token
GITHUB_TOKEN=your_github_token_here

# Alternative to GITHUB_TOKEN (optional)
# PAT=your_github_personal_access_token

# Production URL for metadata and Open Graph (optional; defaults to https://issuescout.dev)
# Override for preview deployments, e.g. https://preview-xyz.vercel.app
# NEXT_PUBLIC_SITE_URL=https://issuescout.dev

# Upstash Redis (required; for caching)
# From Upstash Console or Vercel Marketplace Upstash integration
# If using Vercel Upstash KV, the integration may expose KV_REDIS_REST_URL/TOKEN;
# map those to UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
