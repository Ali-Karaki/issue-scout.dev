# GitHub token (deployment only; used by /api/cron/refresh to fetch from GitHub API)
# Set in Vercel and optionally in GitHub Actions. Not required for user-facing API.
GITHUB_TOKEN=your_github_token_here

# Production URL for metadata and Open Graph (optional; defaults to https://www.issue-scout.dev)
# Override for preview deployments, e.g. https://preview-xyz.vercel.app
# NEXT_PUBLIC_SITE_URL=https://www.issue-scout.dev

# Upstash Redis (required; for caching)
# From Upstash Console or Vercel Marketplace Upstash integration
# If using Vercel Upstash KV, the integration may expose KV_REDIS_REST_URL/TOKEN;
# map those to UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Secret for protecting /api/cron/refresh (required for production)
# Something like: openssl rand -hex 32
# CRON_SECRET=your_random_secret
