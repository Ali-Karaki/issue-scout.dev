# GitHub token (required; for API rate limits)
# Copy to .env.local and add your token
GITHUB_TOKEN=your_github_token_here

# Production URL for metadata and Open Graph (optional; defaults to https://issuescout.dev)
# Override for preview deployments, e.g. https://preview-xyz.vercel.app
# NEXT_PUBLIC_SITE_URL=https://issuescout.dev

# Upstash Redis (required; for caching)
# From Upstash Console or Vercel Marketplace Upstash integration (add with custom prefix UPSTASH)
UPSTASH_REDIS_REST_URL=[str]
UPSTASH_REDIS_REST_TOKEN=[str]
